<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.OrchardDex.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_native_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/loading_logo_splash</item>
        <item name="windowSplashScreenAnimationDuration">60</item>
        <item name="postSplashScreenTheme">@style/Theme.OrchardDex</item>
    </style>

    <style name="Theme.OrchardDex" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>
</resources>
